generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // For Vercel: database is in /tmp (ephemeral, resets on deploy)
  // For local development: database is in prisma/dev.db
  // For production with persistent storage: use PostgreSQL instead
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  funding_pending
  funds_received
  in_progress
  delivered
}

enum QuoteStatus {
  pending
  sent
  approved
  rejected
}

model ProjectRequest {
  id          String        @id @default(cuid())
  projectId   String        @unique
  projectName String
  wishes      String
  services    String
  budgetUsd   Int?
  status      ProjectStatus @default(funding_pending)

  // Quote fields
  quotedAmount   Int?
  quoteStatus    QuoteStatus @default(pending)
  quoteNotes     String?
  quoteValidUntil DateTime?
  
  // Timeline
  estimatedWeeks Int?
  startDate      DateTime?
  deliveryDate   DateTime?

  userName    String
  userEmail   String

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}
