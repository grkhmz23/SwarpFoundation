generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  funding_pending
  funds_received
  in_progress
  delivered
}

model ProjectRequest {
  id          String        @id @default(cuid())
  projectId   String        @unique
  projectName String
  wishes      String
  services    String
  budgetUsd   Int?
  status      ProjectStatus @default(funding_pending)

  userName    String
  userEmail   String

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}
