# Base
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Database
# Local development: file:./prisma/dev.db
# Vercel production: file:/tmp/dev.db (ephemeral - data resets on each deployment)
# For persistent data on Vercel, use PostgreSQL: postgresql://user:pass@host/db
DATABASE_URL="file:./prisma/dev.db"

# Admin access (comma-separated emails)
ADMIN_EMAILS=admin@swarppay.com

# Google OAuth (required for /auth/signin and /dashboard)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# SMTP (used by contact form and dashboard requests)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_TO_EMAIL=info@swarppay.com
# Dashboard intake requests are always sent to info@swarppay.com

# ============================================================================
# SWARP AI - LLM Provider Configuration
# ============================================================================
# Choose your provider: "openrouter" (recommended), "groq", or "together"
SWARP_AI_PROVIDER=openrouter

# API Keys (only need ONE based on provider above):
# OpenRouter (recommended - supports Qwen, Llama, Mistral free tier)
OPENROUTER_API_KEY=your-openrouter-api-key

# Groq (fastest - 14,400 req/day free)
GROQ_API_KEY=your-groq-api-key

# Together AI ($25 free credits)
TOGETHER_API_KEY=your-together-api-key

# Model selection (provider-specific):
# OpenRouter free models:
#   - qwen/qwen3-coder:free (recommended for coding)
#   - qwen/qwen2.5-72b-instruct:free
#   - meta-llama/llama-3.1-8b-instruct:free
#   - mistralai/mistral-7b-instruct:free
#   - google/gemini-2.0-flash-exp:free
# Groq models:
#   - llama-3.3-70b-versatile
#   - llama-3.1-8b-instant
#   - mixtral-8x7b-32768
# Together AI models:
#   - meta-llama/Llama-3.3-70B-Instruct-Turbo
#   - meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
SWARP_AI_MODEL=qwen/qwen3-coder:free

# Allowed origins for CORS (comma-separated)
SWARP_AI_ALLOWED_ORIGINS=http://localhost:3000,https://swarppay.com,https://www.swarppay.com

# Public bank account details shown in dashboard
NEXT_PUBLIC_BANK_BENEFICIARY=SWARP FOUNDATION S.R.L.
NEXT_PUBLIC_BANK_NAME=
NEXT_PUBLIC_BANK_IBAN=
NEXT_PUBLIC_BANK_SWIFT=
NEXT_PUBLIC_BANK_REFERENCE_PREFIX=PROJECT
